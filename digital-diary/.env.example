# The Digital Diary - Environment Variables Template
# Copy this file to .env.local and populate with your own keys. Do not commit actual secrets!

# GitHub Connection Settings
GITHUB_TOKEN=your-fine-grained-github-pat-here
GITHUB_OWNER=your-github-username-here
GITHUB_REPO=your-diary-data-repository-name-here
GITHUB_BRANCH=main

# Security & Access Verification
ALLOWED_GITHUB_USERNAME=your-github-username-here
SESSION_SECRET=a-very-long-random-fallback-secret-here

# GitHub OAuth Settings (Required for v1.2.0+)
GITHUB_CLIENT_ID=your-github-oauth-client-id-here
GITHUB_CLIENT_SECRET=your-github-oauth-client-secret-here

# Application Configuration
NEXT_PUBLIC_APP_NAME=The Digital Diary
